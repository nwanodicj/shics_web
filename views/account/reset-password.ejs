<h1>Reset Your Password</h1>

<div class="notice-info" style="background: #e3f2fd; border: 1px solid #2196f3; border-radius: 8px; color: #1565c0; padding: 1rem 1.1rem; margin-bottom: 1.5rem;">
  <strong>Security Notice:</strong> For your account safety, you must set a new password before accessing your dashboard. This is a one-time requirement.
</div>

<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="error-message" style="background: #ffe6e6; border: 1px solid #d62828; border-radius: 8px; color: #7a1414; padding: 1rem 1.1rem; margin-bottom: 1.5rem;">
    <%= errorMessage %>
  </div>
<% } %>

<fieldset>
  <form class="account-form" action="/account/reset-password" method="post">
  
    <!-- Display User Name -->
    <div class="user-info" style="background: #f5f5f5; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">
      <p style="margin: 0; color: #666;">
        <strong>Hello, <%= userName %>!</strong> Please create a new secure password to continue.
      </p>
    </div>

    <!-- New Password -->
    <label for="newPassword">New Password:</label>
    <input 
      type="password" 
      name="new_password" 
      id="newPassword" 
      required 
      pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">
    
    <!-- Confirm Password -->
    <label for="confirmPassword">Confirm Password:</label>
    <input 
      type="password" 
      name="confirm_password" 
      id="confirmPassword" 
      required 
      pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">

    <!-- Password Instructions -->
    <div class="password-info">
      Password must be at least 12 characters and include:
      uppercase, lowercase, number, and special character.
    </div>
    
    <!-- Show password toggle -->
    <button type="button" id="togglePassword">Show Password</button>
  
    <!-- Submit Button -->
    <button type="submit">Update Password & Continue</button>
  
  </form>

</fieldset>

<script>
  (function() {
    const newPassword = document.getElementById('newPassword')
    const confirmPassword = document.getElementById('confirmPassword')
    const toggle = document.getElementById('togglePassword')
    if (!newPassword || !confirmPassword || !toggle) return
    toggle.addEventListener('click', () => {
      const show = newPassword.type === 'password'
      newPassword.type = show ? 'text' : 'password'
      confirmPassword.type = show ? 'text' : 'password'
      toggle.textContent = show ? 'Hide Password' : 'Show Password'
    })
  })()
</script>
