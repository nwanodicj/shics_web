<h1>Parent Dashboard</h1>
<p>Welcome <%= user.name %></p>
<p>Role: <strong><%= user.role %></strong></p>

<div style="margin-bottom: 2rem;">
  <a href="/dashboard">Back to Dashboard</a>
</div>

<div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
  <aside style="width: 220px; padding: 1rem; border: 1px solid #ddd; border-radius: 6px; background: #f8f9fa;">
    <h3>Quick Links</h3>
    <ul>
      <li><a href="#overview">Overview</a></li>
      <li><a href="#children">My Children</a></li>
      <li><a href="#results">Children's Results</a></li>
      <li><a href="#profile-form">Complete Profile</a></li>
    </ul>
  </aside>

  <div style="flex: 1; min-width: 280px;">
    <section id="overview" style="margin-bottom: 2rem; padding: 1rem; border: 1px solid #ddd; border-radius: 4px;">
      <h2>My Information</h2>
      <table style="width: 100%; border-collapse: collapse;">
        <tr>
          <td style="border: 1px solid #ddd; padding: 0.5rem;"><strong>Name</strong></td>
          <td style="border: 1px solid #ddd; padding: 0.5rem;"><%= user.name || "N/A" %></td>
        </tr>
        <tr>
          <td style="border: 1px solid #ddd; padding: 0.5rem;"><strong>Email</strong></td>
          <td style="border: 1px solid #ddd; padding: 0.5rem;"><%= user.email || "N/A" %></td>
        </tr>
        <tr>
          <td style="border: 1px solid #ddd; padding: 0.5rem;"><strong>Phone</strong></td>
          <td style="border: 1px solid #ddd; padding: 0.5rem;"><%= user.phone || "Not provided" %></td>
        </tr>
        <tr>
          <td style="border: 1px solid #ddd; padding: 0.5rem;"><strong>Address</strong></td>
          <td style="border: 1px solid #ddd; padding: 0.5rem;"><%= user.address || "Not provided" %></td>
        </tr>
      </table>
    </section>

<!-- ============================================
     SECTION 1: MY CHILDREN (READ-ONLY)
     ============================================ -->
<section id="children" style="margin-bottom: 2rem; padding: 1rem; border: 1px solid #ddd; border-radius: 4px;">
  <h2>My Children</h2>
  <% if (children && children.length > 0) { %>
    <table border="1" cellpadding="6" cellspacing="0" style="width: 100%;">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% children.forEach(child => { %>
          <tr>
            <td><%= child.name || "N/A" %></td>
            <td><%= child.email || "N/A" %></td>
            <td><%= child.role || "N/A" %></td>
            <td>
              <a href="/parent/download-report/<%= child.id %>" target="_blank" rel="noopener">Report Card</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No children linked to your account yet. Please contact the school administration.</p>
  <% } %>
</section>

<!-- ============================================
     SECTION 2: CHILDREN'S RESULTS (READ-ONLY)
     ============================================ -->
<section id="results" style="margin-bottom: 2rem; padding: 1rem; border: 1px solid #ddd; border-radius: 4px;">
  <h2>Children's Results</h2>
  <% if (results && results.length > 0) { %>
    <table border="1" cellpadding="6" cellspacing="0" style="width: 100%;">
      <thead>
        <tr>
          <th>Child Name</th>
          <th>Subject</th>
          <th>Score</th>
          <th>Term</th>
        </tr>
      </thead>
      <tbody>
        <% results.forEach(result => { %>
          <tr>
            <td><%= result.name || "N/A" %></td>
            <td><%= result.subject || "N/A" %></td>
            <td><%= result.score || "N/A" %></td>
            <td><%= result.term || "N/A" %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No results available yet.</p>
  <% } %>
</section>

<section id="profile-form" style="margin-bottom: 2rem; padding: 1rem; border: 1px solid #ddd; border-radius: 4px;">
  <h2>Complete Your Profile</h2>
  <p>Add your remaining bio details and profile picture here.</p>
  <form action="/parent/update-profile" method="post" enctype="multipart/form-data">
    <div style="margin-bottom: 0.75rem;">
      <label for="phone">Phone Number</label><br>
      <input type="text" id="phone" name="phone" value="<%= user.phone || "" %>">
    </div>

    <div style="margin-bottom: 0.75rem;">
      <label for="address">Home Address</label><br>
      <textarea id="address" name="address" rows="3"><%= user.address || "" %></textarea>
    </div>

    <div style="margin-bottom: 0.75rem;">
      <label for="date_of_birth">Date of Birth</label><br>
      <input type="date" id="date_of_birth" name="date_of_birth" value="<%= user.date_of_birth || "" %>">
    </div>

    <div style="margin-bottom: 0.75rem;">
      <label for="guardian_name">Guardian Name</label><br>
      <input type="text" id="guardian_name" name="guardian_name" value="<%= user.guardian_name || "" %>">
    </div>

    <div style="margin-bottom: 0.75rem;">
      <label for="bio">Short Bio</label><br>
      <textarea id="bio" name="bio" rows="4"><%= user.bio || "" %></textarea>
    </div>

    <div style="margin-bottom: 0.75rem;">
      <label for="profilePicture">Profile Picture</label><br>
      <input type="file" id="profilePicture" name="profilePicture" accept="image/*">
    </div>

    <% if (user.profile_picture) { %>
      <div style="margin-bottom: 0.75rem;">
        <img src="<%= user.profile_picture %>" alt="Current profile" style="max-width: 120px; border-radius: 50%;">
      </div>
    <% } %>

    <button type="submit">Save Profile</button>
  </form>
</section>
  </div>
</div>