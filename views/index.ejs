    <script>
        /* =========================================
           LOAD ANNOUNCEMENTS (MATCH YOUR CSS)
        ========================================= */
        async function loadAnnouncements() {
        
          const container = document.getElementById("landingAnnouncementList")
        
          try {
            const res = await fetch("/api/announcements")
            const data = await res.json()
        
            container.innerHTML = ""
        
            if (data.length === 0) {
              container.innerHTML = "<p class='mes-parag'>No announcements yet</p>"
              return
            }
        
            data.forEach(a => {
        
              const item = `
                <aside class="announcement-content">
                  <img src="/images/people/calendar-days.svg" alt="icon">
                  <p class="mes-parag">${a.title}</p>
                  <p class="date-parag">
                    ${new Date(a.created_at).toLocaleDateString()}
                  </p>
                </aside>
              `
        
              container.innerHTML += item
            })
        
          } catch (err) {
            console.error(err)
            container.innerHTML = "<p class='mes-parag'>Error loading announcements</p>"
          }
        }
        
        /* Load on page start */
        loadAnnouncements()
    </script>
