<h1>Student Dashboard</h1>

<h2>Profile</h2>
<p><strong>Name:</strong> <%= student.name %></p>
<p><strong>Email:</strong> <%= student.email %></p>

<hr>

<h2>Results</h2>

<% if (results.length > 0) { %>
  <ul>
    <% results.forEach(r => { %>
      <li>
        <strong><%= r.subject %></strong> - <%= r.score %> (<%= r.term %>)
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <p>No results yet</p>
<% } %>

<hr>

<h2>Lesson Notes</h2>

<% if (lessons.length > 0) { %>
  <ul>
    <% lessons.forEach(l => { %>
      <li>
        <strong><%= l.title %></strong>
        <br>
        <a href="<%= l.file_url %>" target="_blank">Download</a>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <p>No lesson notes available</p>
<% } %>
<a href="/student/download-report">
  <button>Download Report Card</button>
</a>