<h2>Upload Lesson</h2>

<form action="/staff/upload-lesson" method="POST" enctype="multipart/form-data">

  <input type="text" name="title" placeholder="Lesson Title" required>

  <input type="text" name="subject" placeholder="Subject" required>

  <input type="text" name="class" placeholder="Class" required>

  <input type="text" name="term" placeholder="Term" required>

  <select name="type" required>
    <option value="">Select Type</option>
    <option value="lesson_note">Lesson Note</option>
    <option value="lesson_plan">Lesson Plan</option>
  </select>

  <input type="file" name="file" required>

  <button type="submit">Upload</button>

</form>

<script>
async function checkIn() {
  const staffId = document.getElementById("staffSelect").value

  const res = await fetch("/attendance/check-in", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ staffId })
  })

  const data = await res.json()
  alert(data.message)
}

async function checkOut() {
  const staffId = document.getElementById("staffSelect").value

  const res = await fetch("/attendance/check-out", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ staffId })
  })

  const data = await res.json()
  alert(data.message)
}
</script>
<script src="/js/attendance-ui.js"></script>